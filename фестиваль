<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Клубничный Фестиваль × Выпускной | Белореченск</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --primary: #ff3860;
            --secondary: #ffdd57;
            --accent: #23d160;
            --dark: #2a2a2a;
            --light: #fff9f9;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Montserrat', sans-serif;
        }
        
        body {
            overflow-x: hidden;
            background-color: var(--light);
            color: var(--dark);
        }
        
        /* Анимации */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        
        /* Header */
        header {
            background: linear-gradient(135deg, #ff3860 0%, #ff7a5c 100%);
            height: 100vh;
            position: relative;
            overflow: hidden;
        }
        
        .hero-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            z-index: 10;
            width: 90%;
            max-width: 1200px;
        }
        
        h1 {
            font-size: 5rem;
            margin-bottom: 1rem;
            text-shadow: 3px 3px 0 rgba(0,0,0,0.1);
            color: white;
        }
        
        .subtitle {
            font-size: 2.2rem;
            color: var(--secondary);
            margin-bottom: 2rem;
            font-weight: 700;
        }
        
        .strawberry {
            position: absolute;
            width: 80px;
            animation: float 6s ease-in-out infinite;
            z-index: 1;
            font-size: 3rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        /* Форма волны */
        .wave {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            overflow: hidden;
            line-height: 0;
        }
        
        .wave svg {
            position: relative;
            display: block;
            width: calc(100% + 1.3px);
            height: 150px;
        }
        
        /* Секции */
        section {
            padding: 100px 5%;
            position: relative;
        }
        
        .section-title {
            text-align: center;
            font-size: 3rem;
            margin-bottom: 60px;
            color: var(--primary);
            position: relative;
        }
        
        .section-title:after {
            content: "🍓";
            position: absolute;
            bottom: -25px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 2rem;
        }
        
        /* О фестивале */
        .about-content {
            display: flex;
            align-items: center;
            gap: 50px;
            flex-wrap: wrap;
        }
        
        .about-text {
            flex: 1;
            min-width: 300px;
        }
        
        .about-image {
            flex: 1;
            min-width: 300px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }
        
        .about-image img {
            width: 100%;
            height: auto;
            display: block;
            transition: transform 0.5s ease;
        }
        
        .about-image:hover img {
            transform: scale(1.05);
        }
        
        /* Программа */
        .timeline {
            position: relative;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .timeline::after {
            content: '';
            position: absolute;
            width: 6px;
            background-color: var(--primary);
            top: 0;
            bottom: 0;
            left: 50%;
            margin-left: -3px;
        }
        
        .event {
            padding: 20px 40px;
            position: relative;
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            width: 45%;
            margin-bottom: 50px;
        }
        
        .event:nth-child(odd) {
            left: 0;
        }
        
        .event:nth-child(even) {
            left: 55%;
        }
        
        .event::after {
            content: "🍓";
            position: absolute;
            width: 40px;
            height: 40px;
            background-color: white;
            border: 4px solid var(--primary);
            border-radius: 50%;
            top: 20px;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }
        
        .event:nth-child(odd)::after {
            right: -60px;
        }
        
        .event:nth-child(even)::after {
            left: -60px;
        }
        
        /* Билеты */
        .tickets {
            background-color: #fff0f3;
        }
        
        .ticket-cards {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .ticket-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            width: 300px;
            transition: all 0.3s ease;
        }
        
        .ticket-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        
        .ticket-header {
            background: var(--primary);
            color: white;
            padding: 30px 20px;
            text-align: center;
        }
        
        .ticket-price {
            font-size: 3rem;
            font-weight: 700;
            margin: 10px 0;
        }
        
        .ticket-body {
            padding: 30px;
        }
        
        .ticket-features {
            list-style: none;
            margin: 20px 0;
        }
        
        .ticket-features li {
            padding: 10px 0;
            border-bottom: 1px solid #eee;
            display: flex;
            align-items: center;
        }
        
        .ticket-features li:before {
            content: "🍓";
            margin-right: 10px;
        }
        
        .ticket-features li:last-child {
            border-bottom: none;
        }
        
        .btn {
            display: block;
            background: var(--primary);
            color: white;
            text-align: center;
            padding: 15px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            margin-top: 20px;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
        }
        
        .btn:hover {
            background: #ff1a4a;
            transform: scale(1.05);
        }
        
        /* Галерея */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .gallery-item {
            border-radius: 15px;
            overflow: hidden;
            height: 300px;
            position: relative;
        }
        
        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        
        .gallery-item:hover img {
            transform: scale(1.1);
        }
        
        /* Контакты */
        .contact-info {
            display: flex;
            flex-wrap: wrap;
            gap: 50px;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .contact-card {
            flex: 1;
            min-width: 300px;
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        
        .contact-card h3 {
            margin-bottom: 20px;
            color: var(--primary);
        }
        
        .social-links {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }
        
        .social-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        .social-icon:hover {
            transform: translateY(-5px);
            background: #ff1a4a;
        }
        
        /* Формы */
        .form-container {
            max-width: 600px;
            margin: 50px auto;
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.1);
        }
        
        .form-group {
            margin-bottom: 25px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #555;
        }
        
        .form-control {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #eee;
            border-radius: 12px;
            font-size: 1rem;
            transition: border-color 0.3s;
        }
        
        .form-control:focus {
            border-color: var(--primary);
            outline: none;
        }
        
        .form-footer {
            text-align: center;
            margin-top: 30px;
        }
        
        /* Футер */
        footer {
            background: var(--dark);
            color: white;
            text-align: center;
            padding: 40px 20px;
        }
        
        /* Модальное окно */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        
        .modal-content {
            background: white;
            border-radius: 20px;
            padding: 40px;
            max-width: 500px;
            width: 90%;
            position: relative;
            animation: modalAppear 0.4s ease;
        }
        
        @keyframes modalAppear {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        
        .close-modal {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 1.5rem;
            cursor: pointer;
            color: #777;
        }
        
        /* Адаптивность */
        @media (max-width: 768px) {
            h1 {
                font-size: 3rem;
            }
            
            .subtitle {
                font-size: 1.5rem;
            }
            
            .event {
                width: 100%;
                left: 0 !important;
                margin-left: 30px;
            }
            
            .event::after {
                left: -60px !important;
                right: auto !important;
            }
            
            .timeline::after {
                left: 30px;
            }
            
            .form-container {
                padding: 25px;
            }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Шапка с анимацией -->
    <header>
        <div class="strawberry" style="top:10%; left:10%;">🍓</div>
        <div class="strawberry" style="top:20%; right:15%; animation-delay: 1s;">🍓</div>
        <div class="strawberry" style="top:60%; left:20%; animation-delay: 2s;">🍓</div>
        <div class="strawberry" style="top:40%; right:25%; animation-delay: 3s;">🍓</div>
        
        <nav style="position: absolute; top: 20px; right: 20px; z-index: 100;">
            <a href="#tickets" class="btn">Купить билеты</a>
        </nav>
        
        <div class="hero-content">
            <h1>КЛУБНИЧНЫЙ ФЕСТ</h1>
            <div class="subtitle">БЕЛОРЕЧЕНСК × ВЫПУСКНОЙ</div>
            <p style="color: white; font-size: 1.5rem; margin-bottom: 40px; max-width: 800px; margin-left: auto; margin-right: auto;">
                Самый сочный фестиваль России! 3 дня клубничного безумия и незабываемый выпускной вечер
            </p>
            <a href="#tickets" class="btn" style="margin: 0 auto; width: 250px; animation: pulse 2s infinite;">
                КУПИТЬ БИЛЕТЫ
            </a>
        </div>
        
        <div class="wave">
            <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="#FFFFFF"></path>
            </svg>
        </div>
    </header>

    <!-- О фестивале -->
    <section id="about">
        <h2 class="section-title">О ФЕСТИВАЛЕ</h2>
        <div class="about-content">
            <div class="about-text">
                <p style="margin-bottom: 20px; font-size: 1.2rem; line-height: 1.8;">
                    Добро пожаловать на главный клубничный фестиваль России! В этом году мы объединяем два грандиозных события: 
                    традиционный фестиваль клубники и выпускной вечер для школьников Белореченска.
                </p>
                <p style="margin-bottom: 20px; font-size: 1.2rem; line-height: 1.8;">
                    Вас ждут: 50+ сортов клубники со всей России, кулинарные шедевры от лучших шеф-поваров, фермерский рынок, 
                    развлекательные зоны для всех возрастов и грандиозный выпускной вечер с участием топовых артистов.
                </p>
                <p style="margin-bottom: 20px; font-size: 1.2rem; line-height: 1.8;">
                    <strong>Дата проведения:</strong> 25-27 июня 2023 года<br>
                    <strong>Место:</strong> Центральный парк культуры и отдыха, Белореченск<br>
                    <strong>Время работы:</strong> 10:00 - 22:00
                </p>
                <a href="#program" class="btn" style="display: inline-block; margin-top: 20px;">Программа фестиваля</a>
            </div>
            <div class="about-image">
                <img src="https://images.unsplash.com/photo-1468908628221-e1b9c7860a5e?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1200&q=80" alt="Фестиваль клубники">
            </div>
        </div>
    </section>

    <!-- Программа -->
    <section id="program" style="background-color: #f8f9fa;">
        <h2 class="section-title">ПРОГРАММА</h2>
        <div class="timeline">
            <div class="event">
                <h3>25 июня: Открытие фестиваля</h3>
                <ul style="list-style: none; margin-top: 15px;">
                    <li>10:00 - Торжественное открытие</li>
                    <li>11:00 - Парад клубничных королев</li>
                    <li>13:00 - Мастер-классы от шеф-поваров</li>
                    <li>16:00 - Конкурс "Самая большая клубника"</li>
                    <li>19:00 - Концерт местных коллективов</li>
                </ul>
            </div>
            
            <div class="event">
                <h3>26 июня: День вкуса</h3>
                <ul style="list-style: none; margin-top: 15px;">
                    <li>10:00 - Ярмарка фермерских продуктов</li>
                    <li>12:00 - Дегустация сортов клубники</li>
                    <li>14:00 - Кулинарные баттлы</li>
                    <li>17:00 - Детская игровая программа</li>
                    <li>20:00 - Выступление DJ-сета</li>
                </ul>
            </div>
            
            <div class="event">
                <h3>27 июня: Выпускной вечер</h3>
                <ul style="list-style: none; margin-top: 15px;">
                    <li>18:00 - Торжественная часть</li>
                    <li>19:30 - Фуршет с клубничными десертами</li>
                    <li>21:00 - Концерт с участием звезд</li>
                    <li>23:00 - Фейерверк над городом</li>
                    <li>00:00 - Танцы до утра</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Билеты -->
    <section id="tickets" class="tickets">
        <h2 class="section-title">БИЛЕТЫ</h2>
        <div class="ticket-cards">
            <div class="ticket-card">
                <div class="ticket-header">
                    <h3>СТАНДАРТ</h3>
                    <div class="ticket-price">500₽</div>
                    <p>1 день фестиваля</p>
                </div>
                <div class="ticket-body">
                    <ul class="ticket-features">
                        <li>Вход на фестиваль</li>
                        <li>Участие в дегустациях</li>
                        <li>Карта фестиваля</li>
                        <li>Сувенирный магнит</li>
                    </ul>
                    <button class="btn" onclick="openModal('standard')">КУПИТЬ</button>
                </div>
            </div>
            
            <div class="ticket-card">
                <div class="ticket-header">
                    <h3>VIP</h3>
                    <div class="ticket-price">2000₽</div>
                    <p>Все дни фестиваля</p>
                </div>
                <div class="ticket-body">
                    <ul class="ticket-features">
                        <li>Весь доступ STANDART</li>
                        <li>VIP-зона с напитками</li>
                        <li>Фирменный мерч</li>
                        <li>Закрытый фуршет</li>
                        <li>Фото с участниками</li>
                    </ul>
                    <button class="btn" onclick="openModal('vip')">КУПИТЬ</button>
                </div>
            </div>
            
            <div class="ticket-card">
                <div class="ticket-header">
                    <h3>ВЫПУСКНОЙ</h3>
                    <div class="ticket-price">1500₽</div>
                    <p>Только 27 июня</p>
                </div>
                <div class="ticket-body">
                    <ul class="ticket-features">
                        <li>Торжественная часть</li>
                        <li>Концертная программа</li>
                        <li>Фуршет с десертами</li>
                        <li>Фотосессия</li>
                        <li>Памятный подарок</li>
                    </ul>
                    <button class="btn" onclick="openModal('graduation')">КУПИТЬ</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Галерея -->
    <section id="gallery">
        <h2 class="section-title">ГАЛЕРЕЯ</h2>
        <div class="gallery-grid">
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1598171707950-9bcc5e258b7a?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=800&q=80" alt="Клубника">
            </div>
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=800&q=80" alt="Фестиваль">
            </div>
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1527525443983-6e60c75fff46?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=800&q=80" alt="Концерт">
            </div>
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1547658719-da2b51169166?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=800&q=80" alt="Выпускной">
            </div>
        </div>
    </section>

    <!-- Контакты -->
    <section id="contact">
        <h2 class="section-title">КОНТАКТЫ</h2>
        <div class="contact-info">
            <div class="contact-card">
                <h3>ОРГКОМИТЕТ</h3>
                <p><i class="fas fa-map-marker-alt"></i> г. Белореченск, ул. Красная, 15</p>
                <p><i class="fas fa-phone"></i> +7 (999) 123-45-67</p>
                <p><i class="fas fa-envelope"></i> info@strawberryfest.ru</p>
                
                <div class="social-links">
                    <a href="#" class="social-icon"><i class="fab fa-vk"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-telegram"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
            
            <div class="contact-card">
                <h3>ДЛЯ ПАРТНЁРОВ</h3>
                <p><i class="fas fa-user-tie"></i> Владислав, директор фестиваля</p>
                <p><i class="fas fa-phone"></i> +7 (ХХХ) ХХХ-ХХ-ХХ</p>
                <p><i class="fas fa-envelope"></i> partner@strawberryfest.ru</p>
                <a href="#" class="btn" style="margin-top: 20px;">Скачать медиа-кит</a>
            </div>
        </div>
    </section>

    <!-- Форма заказа -->
    <div id="orderModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal()">&times;</span>
            <h2 style="text-align: center; margin-bottom: 30px;">Оформление заказа</h2>
            
            <form id="orderForm" onsubmit="submitOrder(event)">
                <input type="hidden" id="ticketType" value="">
                
                <div class="form-group">
                    <label>Выбранный билет</label>
                    <input type="text" id="selectedTicket" class="form-control" readonly>
                </div>
                
                <div class="form-group">
                    <label>Количество билетов</label>
                    <input type="number" id="quantity" class="form-control" min="1" value="1" required>
                </div>
                
                <div class="form-group">
                    <label>Имя и Фамилия</label>
                    <input type="text" id="fullName" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="email" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label>Телефон</label>
                    <input type="tel" id="phone" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label>Комментарий (необязательно)</label>
                    <textarea id="comment" class="form-control" rows="3"></textarea>
                </div>
                
                <button type="submit" class="btn">Перейти к оплате</button>
            </form>
        </div>
    </div>

    <!-- Футер -->
    <footer>
        <p>© 2026 Клубничный фестиваль × Выпускной вечер | Белореченск</p>
        <p>Самый сладкий праздник лета! Создано с любовью к клубнике 🍓</p>
    </footer>

    <script>
        // Функции для модального окна
        function openModal(ticketType) {
            const modal = document.getElementById('orderModal');
            const ticketInput = document.getElementById('ticketType');
            const ticketName = document.getElementById('selectedTicket');
            
            // Установка типа билета
            let ticketTitle = '';
            let price = 0;
            
            switch(ticketType) {
                case 'standard':
                    ticketTitle = 'Стандартный билет (500₽)';
                    price = 500;
                    break;
                case 'vip':
                    ticketTitle = 'VIP билет (2000₽)';
                    price = 2000;
                    break;
                case 'graduation':
                    ticketTitle = 'Билет на выпускной (1500₽)';
                    price = 1500;
                    break;
            }
            
            ticketInput.value = ticketType;
            ticketName.value = ticketTitle;
            
            modal.style.display = 'flex';
        }
        
        function closeModal() {
            document.getElementById('orderModal').style.display = 'none';
        }
        
        // Обработка отправки формы
        function submitOrder(event) {
            event.preventDefault();
            
            const ticketType = document.getElementById('ticketType').value;
            const quantity = document.getElementById('quantity').value;
            const fullName = document.getElementById('fullName').value;
            const email = document.getElementById('email').value;
            const phone = document.getElementById('phone').value;
            
            // Расчет стоимости
            let price = 0;
            switch(ticketType) {
                case 'standard': price = 500; break;
                case 'vip': price = 2000; break;
                case 'graduation': price = 1500; break;
            }
            
            const totalPrice = price * quantity;
            
            // Показ сообщения об успехе
            alert(`Спасибо за заказ, ${fullName}!\n\nБилеты на сумму ${totalPrice}₽ успешно оформлены!\nНа ваш email (${email}) отправлено подтверждение.`);
            
            // Закрытие модального окна
            closeModal();
            
            // Очистка формы
            document.getElementById('orderForm').reset();
        }
        
        // Закрытие модалки при клике вне ее
        window.onclick = function(event) {
            const modal = document.getElementById('orderModal');
            if (event.target === modal) {
                closeModal();
            }
        }
        
        // Плавная прокрутка
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
        
        // Обратный отсчет до фестиваля
        function updateCountdown() {
            const countdownDate = new Date('June 25, 2024 10:00:00').getTime();
            const now = new Date().getTime();
            const distance = countdownDate - now;
            
            if (distance < 0) {
                document.getElementById('countdown').innerHTML = "Фестиваль начался!";
                return;
            }
            
            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);
            
            document.getElementById('days').innerText = days;
            document.getElementById('hours').innerText = hours;
            document.getElementById('minutes').innerText = minutes;
            document.getElementById('seconds').innerText = seconds;
        }
        
        setInterval(updateCountdown, 1000);
        updateCountdown();
    </script>
</body>
</html>
